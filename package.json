    "build": "tsc && npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "dev": "ts-node -P tsconfig.node.json src/index.ts",
    "dev:server": "ts-node -P tsconfig.node.json src/server.ts",
    "dev:server:watch": "ts-node -P tsconfig.node.json --watch src/server.ts",
    "start:all": "concurrently \"npm run dev:server\" \"cd frontend && npm run dev\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
