  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Typescript",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "runtimeExecutable": "ts-node",
      // "runtimeArgs": ["--nolazy", "-r", "ts-node/register/transpile-only"],
      "args": ["thingy/main.ts"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Javascript",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "runtimeExecutable": "node",
      "args": ["thingy/default.js"]
    }
  ]
}